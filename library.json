  "dependencies": [
    {
      "owner": "adafruit",
      "name": "Adafruit GFX Library",
      "version": "^1.11.0"
    },
    {
      "owner": "adafruit",
      "name": "Adafruit SSD1306",
      "version": "^2.5.7"
    }
